# ── Bus App Backend Configuration ─────────────────────────────────────────────
# Copy this file to .env and fill in the values

APP_ENV=development
PORT=8080
JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5000,http://localhost:5173

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/bus_app
